# API Configuration
VITE_API_URL=https://tile-erp-master-production.up.railway.app
VITE_API_BASE=https://tile-erp-master-production.up.railway.app/api
VITE_API_BASE_URL=https://tile-erp-master-production.up.railway.app/api

# Application Configuration
VITE_APP_NAME=Tile Exporter
VITE_APP_VERSION=2.2.0
VITE_APP_ENV=development

# Feature Flags
VITE_ENABLE_OFFLINE_MODE=false
VITE_ENABLE_PWA=false

# Database Configuration (for reference only - backend handles DB connection)
# Frontend does NOT connect directly to the database
# These are just display values if needed in the UI
VITE_DB_SSH=Disabled
VITE_DB_PREVIEW_LIMIT=50
VITE_DB_SERVER=localhost
VITE_DB_PORT=5432
VITE_DB_DRIVER=PostgreSQL
VITE_DB_NAME="DM Tile Local"
VITE_DB_DATABASE=tile_exporter_crm
VITE_DB_USERNAME=postgres
VITE_DB_PASSWORD=your_password_here
VITE_DB_CONNECTION_TIMEOUT=30

# Analytics (Optional)
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX
# VITE_HOTJAR_ID=XXXXXXX

# Stripe Public Key (Optional)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# Sentry (Optional - Frontend Error Tracking)
# VITE_SENTRY_DSN=https://xxxxxxxxxxxxx@sentry.io/xxxxxxxxxxxxx
