{
  "name": "tile-exporter-backend",
  "version": "1.0.0",
  "description": "Enterprise-grade backend for Tile Exporter Solution",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "init-db": "node init-db.js",
    "setup:master": "node src/database/setupMasterDB.js",
    "migrate": "node src/database/migrate.js",
    "seed": "node seed_master_data.js",
    "db:setup": "npm run setup:master && npm run migrate && npm run seed",
    "lint": "eslint src --ext .js",
    "format": "prettier --write src",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs --forceExit",
    "test:security": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs --testPathPattern=security --forceExit",
    "security:reset-admin-password": "node src/scripts/reset-admin-password.js",
    "build": "echo 'Build complete'"
  },
  "keywords": [
    "tile",
    "export",
    "saas",
    "multi-tenant",
    "postgresql"
  ],
  "author": "Tile Exporter Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "all-the-cities": "^3.1.0",
    "archiver": "^8.0.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "clamscan": "^2.4.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "country-state-city": "^3.2.1",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.1",
    "extract-zip": "^2.0.1",
    "file-type": "^22.0.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.2",
    "multer-s3": "^3.0.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "openai": "^6.17.0",
    "pg": "^8.18.0",
    "puppeteer": "^25.1.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "stripe": "^20.3.0",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^14.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xss": "^1.0.15",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-security": "^4.0.1",
    "javascript-obfuscator": "^5.4.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.3",
    "supertest": "^7.2.2"
  }
}
