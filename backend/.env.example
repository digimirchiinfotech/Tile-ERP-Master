# ========================================
# Development Environment Variables
# Copy this file to .env and fill in your values
#
# SECURITY: Never commit your actual .env file to version control.
# Generate all secrets with: openssl rand -hex 64
# ========================================

# Server Configuration
NODE_ENV=development
PORT=8000
HOST=0.0.0.0

# Database Configuration (Local PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tile_exporter_crm
DB_USER=postgres
DB_PASSWORD=your-strong-db-password

# SECURITY: Generate with: openssl rand -base64 32
# Must be exactly 32 bytes for AES-256 encryption. Do NOT reuse across environments.
DB_ENCRYPTION_KEY=generate-a-32-byte-key-see-above

# JWT Configuration
# SECURITY: Generate with: openssl rand -hex 64
# Must be cryptographically random. NEVER use the example value in production.
JWT_SECRET=generate-with-openssl-rand-hex-64
JWT_REFRESH_SECRET=generate-with-openssl-rand-hex-64
JWT_ACCESS_EXPIRY=4h
JWT_REFRESH_EXPIRY=30d

# Session Secret
# SECURITY: Generate with: openssl rand -hex 32
SESSION_SECRET=generate-with-openssl-rand-hex-32

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5000

# Email Configuration (Optional for local development)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@tileexporter.com

# Logging
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Admin Setup (first-run only)
# SECURITY: Change immediately after first login. Use 20+ character passwords.
ADMIN_PASSWORD=change-this-on-first-login

# ========================================
# Backup & Disaster Recovery (AWS S3)
# SECURITY: Use IAM roles in production instead of access keys.
# ========================================
BACKUP_S3_BUCKET=your-backup-bucket-name
BACKUP_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ========================================
# Optional Integrations (leave blank to disable)
# ========================================
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
